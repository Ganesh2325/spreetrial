*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Testing ─────────────────────────────────────────────────
/coverage

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Misc ────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel
